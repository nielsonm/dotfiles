# SSH Client Configuration Template
# Copy or symlink to ~/.ssh/config

Host *
  AddKeysToAgent yes
  ServerAliveInterval 60
  ServerAliveCountMax 3
  # UseKeychain yes # Uncomment for macOS Keychain integration

# GitHub
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_rsa

