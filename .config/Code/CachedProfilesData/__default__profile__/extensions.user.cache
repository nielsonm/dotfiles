WorkflowFromFailed","title":"Rerun workflow from failed","category":"CircleCI","icon":{"dark":"dist/assets/default/dark/actions/rerun-from-failed.svg","light":"dist/assets/default/light/actions/rerun-from-failed.svg"}},{"command":"circleci.cancelWorkflow","title":"Cancel workflow","category":"CircleCI","icon":{"dark":"dist/assets/default/dark/actions/cancel.svg","light":"dist/assets/default/light/actions/cancel.svg"}},{"command":"circleci.rerunWorkflowFromStart","title":"Rerun workflow from start","category":"CircleCI","icon":{"dark":"dist/assets/default/dark/actions/rerun-from-start.svg","light":"dist/assets/default/light/actions/rerun-from-start.svg"}},{"command":"circleci.rerunJobWithSSH","title":"Rerun job with SSH","category":"CircleCI","icon":{"dark":"dist/assets/default/dark/actions/rerun-with-ssh.svg","light":"dist/assets/default/light/actions/rerun-with-ssh.svg"}},{"command":"circleci.rerunJob","title":"Rerun job","category":"CircleCI","icon":{"dark":"dist/assets/default/dark/actions/rerun-from-start.svg","light":"dist/assets/default/light/actions/rerun-from-start.svg"}},{"command":"circleci.openInBrowser","title":"Open in browser","category":"CircleCI","icon":"$(link-external)"},{"command":"circleci.openPipelineYAML","title":"Open pipeline YAML","category":"CircleCI","icon":"$(file-code)"},{"command":"circleci.openPipelineConfigErrors","title":"Show error logs","icon":"$(output-view-icon)"},{"command":"circleci.cancelJob","title":"Cancel job","category":"CircleCI","icon":{"dark":"dist/assets/default/dark/actions/cancel.svg","light":"dist/assets/default/light/actions/cancel.svg"}},{"command":"circleci.logout","title":"Log Out","category":"CircleCI"},{"command":"circleci.localRun.runCommandPalette","title":"Trigger pipeline using local config","category":"CircleCI"},{"command":"circleci.validateConfigValid","title":"Validate current configuration file","category":"CircleCI","icon":{"dark":"dist/assets/default/dark/circleci-logo.svg","light":"dist/assets/default/light/circleci-logo.svg"},"enablement":"configIsValid == true"},{"command":"circleci.validateConfigInvalid","title":"Validate current configuration file","category":"CircleCI","icon":"dist/assets/default/dark/circleci-logo-red.svg","enablement":"configIsValid == false"},{"command":"circleci.reloadPipelines","title":"Reload pipelines","category":"CircleCI","icon":"$(sync)"},{"command":"circleci.promptJobApproval","title":"Approve Job","category":"CircleCI","icon":"$(play)"},{"command":"circleci.openSettings","title":"Open settings","category":"CircleCI","icon":"$(gear)"},{"command":"circleci.validatePolicy","title":"Validate current configuration file against org policy","category":"CircleCI","icon":"$(gear)"},{"command":"circleci.disableNotifications","title":"Disable workflow status notifications","category":"CircleCI","icon":"$(bell)"},{"command":"circleci.enableNotifications","title":"Enable workflow status notifications","category":"CircleCI","icon":"$(bell-slash)"},{"command":"circleci.languageServer.restartServer","title":"Restart CircleCI Language Server","category":"CircleCI","icon":"$(debug-restart)"},{"command":"circleci.languageServer.updateServer","title":"Update CircleCI Language Server","category":"CircleCI"},{"command":"circleci.languageServer.displayVersion","title":"Display Language Server version","category":"CircleCI"},{"command":"circleci.explorer.copyJobNumber","title":"Copy Job Number","category":"CircleCI"},{"command":"circleci.explorer.copyID","title":"Copy ID","category":"CircleCI"},{"command":"circleci.explorer.ssh.openInTerminal","title":"Debug with SSH in terminal","category":"CircleCI","icon":"$(terminal)"},{"command":"circleci.explorer.ssh.openInRemoteWindow","title":"Debug with SSH in remote window","category":"CircleCI","icon":"$(remote)"},{"command":"circleci.openJobsView","title":"Open job details","category":"CircleCI","icon":"$(eye)"},{"command":"circleci.compileFocusedConfig","title":"View compiled version of current configuration file","category":"CircleCI"},{"command":"circleci.openNewFeatures","title":"Discover new features","category":"CircleCI"},{"command":"circleci.localRun.openConfigFile","title":"Open config.yml","icon":"$(symbol-reference)","category":"CircleCI"},{"command":"circleci.localRun.reloadProject","title":"Reload project","icon":"$(sync)","category":"CircleCI"},{"command":"circleci.sendFeedbackEmail","title":"Send us feedback","icon":{"dark":"dist/assets/default/dark/feedback-gray.svg","light":"dist/assets/default/light/feedback-gray.svg"},"category":"CircleCI"}],"configuration":{"title":"CircleCI","properties":{"circleci.apiToken":{"type":["string","null"],"default":null,"description":"Your access token to the CircleCI public API. You can create a new one at https://app.circleci.com/settings/user/tokens?utm_source=VS_Code_marketplace&utm_medium=marketplace&utm_campaign=CCI_VS_code_marketplace_page"},"circleci.persistedProjectSelection":{"type":"array","items":{"type":"string"},"markdownDescription":"The slugs of the project shown on the sidebar. This value handles only projects you follow, all other slugs will be ignored."},"circleci.filters.myPipelinesOnly":{"type":"boolean","default":false,"markdownDescription":"Whether you want to only see your project or everyone's project.\n\n**Important note**: you can not filter by user and by branch so setting this option to true will force the `\"allBranches\"` value for the branch filter."},"circleci.filters.branchFilter":{"type":"string","default":"currentBranch","enum":["allBranches","default","currentBranch"],"markdownDescription":"What branch you want to see.\n\n - `\"allBranches\"`: see the pipelines for all branches\n\n - `\"default\"`: see the pipelines of the repo's default branch.\nWorks only when all selected projects have a default branch, else falls back to `\"allBranches\"`\n\n - `\"currentBranch\"`: Track your local current branch and see only the pipelines of this branch.\nWorks only when all selected projects are available locally, else falls back to `\"allBranches\"`.\n\n**Important note**: you can not filter by user and by branch so setting this option to anything else than \"allBranches\" will force the `false` value for the \"My pipelines only\" filter."},"circleci.filters.statusFilter":{"type":"object","properties":{"canceled":{"type":"boolean"},"failed":{"type":"boolean"},"failing":{"type":"boolean"},"not_run":{"type":"boolean"},"on_hold":{"type":"boolean"},"success":{"type":"boolean"}},"markdownDescription":"Which statuses you want to see in the sidebar. By default, status are all active, so for example, if you want to not see the `failing` status, add `\"failing\": false` to the JSON.","default":{"canceled":true,"failed":true,"failing":true,"not_run":true,"on_hold":true,"success":true}},"circleci.languageServer.updatePolicy":{"type":"string","default":"default","enum":["default","automatic","prompt","never"],"markdownDescription":"Select when language server should be updated.\n\n - `\"default\"`: fallback to VSCode auto-update policy\n\n - `\"automatic\"`: language server is automatically updated to the latest version when available\n\n - `\"prompt\"`: ask before updating the language server\n\n - `\"never\"`: language server is never updated"},"circleci.hostUrl":{"type":["string","null"],"default":null,"description":"The host URL of your CircleCI instance. If you are using CircleCI Enterprise, you can find this URL in the CircleCI Admin Settings page."},"circleci.theme":{"type":"string","enum":["default"],"default":"default","description":"The theme of your VSCode extension, mainly used for events during the year"},"circleci.ssh.terminalOrRemoteWindow":{"type":"string","description":"When debugging a job with SSH, where to open the shell?","enum":["In a terminal","In a remote SSH window"],"enumDescriptions":["Open a terminal and launches the appropriate SSH command","Open a remote SSH window"],"default":"Always ask"},"circleci.ssh.privateKey.github":{"type":"string","description":"Absolute path to the private key to use when debugging a job with SSH (github)","default":null,"scope":"machine-overridable"},"circleci.ssh.privateKey.bitbucket":{"type":"string","description":"Absolute path to the private key to use when debugging a job with SSH (bitbucket)","default":null,"scope":"machine-overridable"},"circleci.ssh.windows.shell":{"type":"string","description":"Shell to use when debugging a Windows job with SSH in a terminal","enum":["Default shell","bash","cmd","powershell"],"default":"Always ask","scope":"machine-overridable"},"circleci.notifications.mute":{"type":"boolean","description":"Check the box to mute notifications.","default":false},"circleci.notifications.mine":{"type":"boolean","description":"Check the box to always receive notifications only about pipelines you triggered.","default":false},"circleci.notifications.statusFilter":{"type":"object","properties":{"canceled":{"type":"boolean"},"error":{"type":"boolean"},"failed":{"type":"boolean"},"failing":{"type":"boolean"},"not_run":{"type":"boolean"},"on_hold":{"type":"boolean"},"success":{"type":"boolean"},"unauthorized":{"type":"boolean"}},"markdownDescription":"Which statuses you want to receive notifications for. By receive notifications for all workflow statuses except for `running`","default":{"canceled":true,"error":true,"failed":true,"failing":true,"not_run":true,"on_hold":true,"success":false,"unauthorized":true}}}}},"scripts":{"build:prod":"node esbuild.mjs --production","build":"node esbuild.mjs","package":"vsce package -o output.vsix --no-dependencies --yarn","prepackage":"yarn vscode:prepublish && rm -rf vsix && mkdir vsix","test":"vitest run","typecheck":"tsc --noEmit","vscode:prepublish":"cp ../../LICENSE .","watch":"node esbuild.mjs --watch"},"devDependencies":{"@types/cross-spawn":"^6.0.2","@types/getos":"^3.0.1","@types/git-remote-origin-url":"^3.0.1","@types/git-url-parse":"^9.0.1","@types/lodash":"4.17.16","@types/mock-fs":"^4.13.2","@types/n